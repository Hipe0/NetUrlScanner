@model IEnumerable<NetURLScanner.Models.User>

@{
    ViewData["Title"] = "Quản lý Phân quyền";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><i class="bi bi-people me-2"></i>Quản lý người dùng & Phân quyền</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-1"></i>Tạo tài khoản</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-5">
                    <input type="text" name="search" class="form-control" placeholder="Tìm email hoặc họ tên..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-3">
                    <select name="role" class="form-select">
                        <option value="">-- Tất cả vai trò --</option>
                        @if (ViewBag.Role as string == "Admin") { <option value="Admin" selected>Admin</option> } else { <option value="Admin">Admin</option> }
                        @if (ViewBag.Role as string == "Manager") { <option value="Manager" selected>Manager</option> } else { <option value="Manager">Manager</option> }
                        @if (ViewBag.Role as string == "User") { <option value="User" selected>User</option> } else { <option value="User">User</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                    @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Role as string))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary ms-1">Xóa lọc</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Email / Họ tên</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Đổi quyền</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var isProtected = item.Email == ViewBag.ProtectedAdminEmail as string;
                        <tr class="@(!item.IsActive ? "table-secondary" : "")">
                            <td>
                                <div class="fw-semibold">@item.Email</div>
                                @if (!string.IsNullOrEmpty(item.FullName))
                                {
                                    <small class="text-muted">@item.FullName</small>
                                }
                            </td>
                            <td>
                                @if (item.Role == "Admin")
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else if (item.Role == "Manager")
                                {
                                    <span class="badge bg-warning text-dark">Manager</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">User</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã khóa</span>
                                }
                            </td>
                            <td><small>@item.CreatedAt.ToString("dd/MM/yyyy")</small></td>
                            <td>
                                @if (!isProtected)
                                {
                                    <form asp-action="ChangeRole" method="post" class="d-flex align-items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <select name="role" class="form-select form-select-sm" style="width:auto;">
                                            @if (item.Role == "User") { <option value="User" selected>User</option> } else { <option value="User">User</option> }
                                            @if (item.Role == "Manager") { <option value="Manager" selected>Manager</option> } else { <option value="Manager">Manager</option> }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-primary">Lưu</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic small">Admin gốc</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <a asp-action="UserScans" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Lịch sử quét">
                                        <i class="bi bi-clock-history"></i>
                                    </a>
                                    @if (!isProtected)
                                    {
                                        <form asp-action="ToggleActive" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(item.IsActive ? "Khóa" : "Mở khóa")">
                                                <i class="bi @(item.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Xóa tài khoản @item.Email?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
