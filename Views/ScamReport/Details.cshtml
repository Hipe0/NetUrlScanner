@model NetURLScanner.Models.ScamReport

@{
    ViewData["Title"] = "Chi tiết báo cáo";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold mb-0 text-primary">Chi tiết báo cáo #@Model.Id</h3>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">Người báo cáo:</div>
                    <div class="col-sm-8">
                        @if (Model.User != null)
                        {
                            <span class="fw-medium text-dark">@Model.User.Email</span>
                        }
                        else
                        {
                            <span class="fst-italic text-secondary">Khách ẩn danh</span>
                        }
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">Ngày gửi:</div>
                    <div class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">Trạng thái:</div>
                    <div class="col-sm-8">
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark px-3 py-2"><i class="bi bi-hourglass-split me-1"></i>Chờ duyệt</span>
                        }
                        else if (Model.Status == "Approved")
                        {
                            <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i>Đã duyệt</span>
                        }
                        else if (Model.Status == "Rejected")
                        {
                            <span class="badge bg-danger px-3 py-2"><i class="bi bi-x-circle me-1"></i>Đã từ chối</span>
                        }
                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    <label class="text-muted fw-bold mb-2">Loại báo cáo:</label>
                    <div>@(Model.ReportType == "BankAccount" ? "Tài khoản ngân hàng" : "Website / IP")</div>
                </div>

                @if (Model.ReportType == "BankAccount")
                {
                    <div class="mb-3">
                        <label class="text-muted fw-bold mb-2">Ngân hàng / Số TK:</label>
                        <div class="p-3 bg-light rounded border">
                            <div><strong>@Model.BankId</strong> — @Model.BankAccountNumber</div>
                            @if (!string.IsNullOrWhiteSpace(Model.BankAccountOwnerName))
                            {
                                <div class="text-muted small mt-1">Chủ TK: @Model.BankAccountOwnerName</div>
                            }
                            @if (Model.AmountLost.HasValue && Model.AmountLost > 0)
                            {
                                <div class="text-danger fw-semibold mt-1">Thiệt hại: @Model.AmountLost.Value.ToString("N0") VNĐ</div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="text-muted fw-bold mb-2">URL / IP bị báo cáo:</label>
                        <div class="p-3 bg-light rounded text-break font-monospace fw-bold text-danger border">
                            @Model.UrlOrIp
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label class="text-muted fw-bold mb-2">Bằng chứng / Lý do:</label>
                    <div class="p-3 bg-light rounded text-break border" style="white-space: pre-wrap;">@Model.Evidence</div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.EvidenceImagePaths))
                {
                    <div class="mb-3">
                        <label class="text-muted fw-bold mb-2">Ảnh bằng chứng:</label>
                        <div class="evidence-preview">
                            @foreach (var path in Model.EvidenceImagePaths.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <a href="@path.Trim()" target="_blank" rel="noopener">
                                    <img src="@path.Trim()" alt="Bằng chứng" />
                                </a>
                            }
                        </div>
                    </div>
                }

            </div>
            
            @if (Model.Status == "Pending")
            {
                <div class="card-footer bg-white p-3 border-top d-flex justify-content-end gap-2">
                    <form asp-action="Reject" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn TỪ CHỐI báo cáo này không?');">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-x-circle me-1"></i>Từ chối
                        </button>
                    </form>
                    
                    <form asp-action="Approve" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn DUYỆT báo cáo này và tự động thêm vào Blacklist không?');">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Duyệt & Thêm Blacklist
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>
