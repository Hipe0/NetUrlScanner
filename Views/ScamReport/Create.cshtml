@model NetURLScanner.Models.ScamReport
@{
    ViewData["Title"] = "Báo cáo Lừa đảo";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow border-0 scam-report-card overflow-hidden">
                <div class="card-header bg-danger text-white py-4 text-center border-0">
                    <i class="bi bi-shield-exclamation display-6 d-block mb-2"></i>
                    <h3 class="fw-bold mb-1">Báo cáo lừa đảo</h3>
                    <p class="mb-0 small opacity-75">Giúp cộng đồng tránh URL / tài khoản nguy hiểm</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (User?.Identity?.IsAuthenticated != true)
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-lock fs-1 text-muted d-block mb-3"></i>
                            <h5 class="fw-bold">Đăng nhập để gửi báo cáo</h5>
                            <p class="text-muted mb-4">Xác thực tài khoản giúp giảm spam và tăng độ tin cậy.</p>
                            <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/ScamReport/Create" class="btn btn-primary btn-lg px-4">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                            </a>
                        </div>
                    }
                    else
                    {
                        <form asp-action="Create" method="post" enctype="multipart/form-data" id="scamReportForm">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Loại báo cáo</label>
                                <div class="d-flex flex-wrap gap-2">
                                    <input type="radio" class="btn-check" name="ReportType" id="typeUrl" value="Url" checked>
                                    <label class="btn btn-outline-danger" for="typeUrl"><i class="bi bi-globe me-1"></i>Website / IP</label>
                                    <input type="radio" class="btn-check" name="ReportType" id="typeBank" value="BankAccount">
                                    <label class="btn btn-outline-danger" for="typeBank"><i class="bi bi-bank me-1"></i>Tài khoản NH</label>
                                </div>
                            </div>

                            <div id="urlSection" class="mb-4">
                                <label asp-for="UrlOrIp" class="form-label fw-bold">URL hoặc IP đáng ngờ</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                    <input asp-for="UrlOrIp" class="form-control" placeholder="https://... hoặc 192.168.x.x" />
                                </div>
                                <span asp-validation-for="UrlOrIp" class="text-danger small"></span>
                            </div>

                            <div id="bankSection" class="mb-4" hidden>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="BankId" class="form-label fw-bold">Ngân hàng</label>
                                        <select asp-for="BankId" class="form-select" id="bankSelect">
                                            <option value="">-- Chọn --</option>
                                            <option value="OTHER">Khác</option>
                                        </select>
                                        <input type="text" name="customBankName" id="customBankInput" class="form-control mt-2 d-none" placeholder="Tên NH" />
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="BankAccountNumber" class="form-label fw-bold">Số tài khoản</label>
                                        <input asp-for="BankAccountNumber" class="form-control" id="accountNumber" />
                                    </div>
                                    <div class="col-md-8">
                                        <label asp-for="BankAccountOwnerName" class="form-label fw-bold">Tên chủ TK</label>
                                        <input asp-for="BankAccountOwnerName" class="form-control" id="accountOwnerName" readonly />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">&nbsp;</label>
                                        <button type="button" class="btn btn-outline-secondary w-100" id="btnLookup">Tra tên TK</button>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="AmountLost" class="form-label fw-bold">Thiệt hại (VNĐ)</label>
                                        <input asp-for="AmountLost" type="number" class="form-control" min="0" placeholder="Tùy chọn" />
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Evidence" class="form-label fw-bold">Mô tả & bằng chứng</label>
                                <textarea asp-for="Evidence" class="form-control" rows="4" placeholder="Mô tả ngắn gọn: kênh lừa đảo, nội dung tin nhắn, số tiền..."></textarea>
                                <span asp-validation-for="Evidence" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Ảnh bằng chứng <span class="text-muted fw-normal">(tối đa 5 ảnh, 5MB/ảnh)</span></label>
                                <input type="file" name="evidenceImages" class="form-control" accept="image/jpeg,image/png,image/webp" multiple id="evidenceInput" />
                                <div id="evidencePreview" class="evidence-preview"></div>
                            </div>

                            <div class="d-grid gap-2 d-md-flex">
                                <button type="submit" class="btn btn-danger btn-lg flex-grow-1">
                                    <i class="bi bi-send-fill me-2"></i>Gửi báo cáo
                                </button>
                                <a asp-controller="Home" asp-action="Landing" class="btn btn-outline-secondary btn-lg">Hủy</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/bank-select.js" asp-append-version="true" defer></script>
    <script src="~/js/scam-report-form.js" asp-append-version="true" defer></script>
    <script>
        document.getElementById('evidenceInput')?.addEventListener('change', function () {
            const box = document.getElementById('evidencePreview');
            if (!box) return;
            box.innerHTML = '';
            [...this.files].slice(0, 5).forEach(f => {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(f);
                img.alt = f.name;
                box.appendChild(img);
            });
        });
    </script>
}
