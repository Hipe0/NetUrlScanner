@model IEnumerable<NetURLScanner.Models.ScamReport>

@{
    ViewData["Title"] = "Quản lý Báo cáo lừa đảo";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold mb-0 text-danger"><i class="bi bi-shield-exclamation me-2"></i>Quản lý Báo cáo</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3 px-4">Ngày báo cáo</th>
                        <th class="py-3">Người báo cáo</th>
                        <th class="py-3">Mục tiêu báo cáo</th>
                        <th class="py-3">Loại</th>
                        <th class="py-3">Trạng thái</th>
                        <th class="py-3 text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                Chưa có báo cáo nào.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 text-nowrap">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.User != null)
                                    {
                                        <span class="badge bg-info text-dark">@item.User.Email</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Khách ẩn danh</span>
                                    }
                                </td>
                                <td>
                                    @if (item.ReportType == "BankAccount")
                                    {
                                        <div class="text-truncate fw-medium" style="max-width: 250px;" title="@item.BankId - @item.BankAccountNumber">
                                            <i class="bi bi-bank me-1"></i> @item.BankId - @item.BankAccountNumber
                                            @if (!string.IsNullOrEmpty(item.BankAccountOwnerName))
                                            {
                                                <br /><small class="text-muted">(@item.BankAccountOwnerName)</small>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-truncate fw-medium" style="max-width: 250px;" title="@item.UrlOrIp">
                                            <i class="bi bi-link me-1"></i> @item.UrlOrIp
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (item.ReportType == "BankAccount")
                                    {
                                        <span class="badge bg-primary">Ngân hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Website</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chờ duyệt</span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Đã duyệt</span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Đã từ chối</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
