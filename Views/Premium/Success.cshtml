@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="premium-page">
    <section class="text-center py-5">
        <div class="premium-success-icon mb-3">
            <i class="bi bi-check-circle-fill text-success"></i>
        </div>
        <h1 class="premium-hero-title mb-2">Chào mừng đến Pro!</h1>
        <p class="premium-hero-lead mb-4">
            Premium đã được kích hoạt. Bạn có thể dùng OCR và tra cứu ngân hàng ngay bây giờ.
        </p>

        <div class="row g-3 justify-content-center" style="max-width: 520px; margin: 0 auto;">
            <div class="col-sm-6">
                <a asp-controller="OcrScan" asp-action="Index" class="btn btn-warning btn-lg w-100 fw-bold">
                    <i class="bi bi-image me-2"></i>Quét OCR
                </a>
            </div>
            <div class="col-sm-6">
                <a asp-controller="BankAccountChecker" asp-action="Index" class="btn btn-outline-danger btn-lg w-100 fw-bold">
                    <i class="bi bi-bank me-2"></i>Tra cứu NH
                </a>
            </div>
            <div class="col-12">
                <a asp-controller="Premium" asp-action="Index" class="btn btn-link text-muted">Xem chi tiết gói Premium</a>
            </div>
        </div>
    </section>
</div>

<style>
    .premium-success-icon {
        font-size: 4.5rem;
        line-height: 1;
        animation: premiumPop 0.5s ease-out;
    }

    @@keyframes premiumPop {
        0% { transform: scale(0.5); opacity: 0; }
        70% { transform: scale(1.08); }
        100% { transform: scale(1); opacity: 1; }
    }
</style>
