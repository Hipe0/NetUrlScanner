@model NetURLScanner.Models.SiteContent?
@{
    ViewData["Title"] = Model?.Title ?? "Giới thiệu";
}

<div class="container mt-4">
    <div class="mb-4">
        <h1 class="fw-bold">@(Model?.Title ?? "Giới thiệu NetURLScanner")</h1>
        @if (Model != null && !string.IsNullOrWhiteSpace(Model.Body))
        {
            <div class="card shadow-sm border-0 border-start border-primary border-4 mb-4">
                <div class="card-body cms-intro">
                    @Html.Raw(Model.Body)
                </div>
            </div>
        }
        else
        {
            <p class="text-muted">
                NetURLScanner là hệ thống web hỗ trợ kiểm tra trạng thái hoạt động của URL và đánh giá mức độ rủi ro
                dựa trên các đặc điểm kỹ thuật, cấu trúc đường dẫn, dấu hiệu giả mạo tên miền và các rule phân tích bảo mật.
            </p>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">1. Mục tiêu của hệ thống</h4>

            <p>
                Hệ thống được xây dựng nhằm hỗ trợ quản trị viên kiểm tra nhanh một URL bất kỳ để xác định URL đó
                còn hoạt động hay không, phản hồi nhanh hay chậm, có sử dụng HTTPS hay không và có dấu hiệu đáng ngờ
                liên quan đến giả mạo, lừa đảo hoặc cấu trúc bất thường hay không.
            </p>

            <p>
                Sau mỗi lần quét, hệ thống sẽ lưu lại kết quả vào cơ sở dữ liệu SQL Server, bao gồm thông tin URL,
                trạng thái hoạt động, mã phản hồi HTTP, thời gian phản hồi, điểm rủi ro, mức độ rủi ro và lý do đánh giá.
                Nhờ đó, quản trị viên có thể theo dõi lịch sử kiểm tra và phân tích lại các URL đã quét.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">2. Cách hệ thống quét URL</h4>

            <p>
                Khi người dùng nhập một URL và bấm nút <strong>Scan</strong>, hệ thống sẽ xử lý theo các bước sau:
            </p>

            <ol>
                <li>
                    <strong>Chuẩn hóa URL:</strong>
                    nếu người dùng nhập thiếu giao thức, ví dụ <code>google.com</code>, hệ thống sẽ tự động chuyển thành
                    <code>https://google.com</code>.
                </li>

                <li>
                    <strong>Gửi request đến URL:</strong>
                    hệ thống sử dụng <code>HttpClient</code> trong ASP.NET Core để gửi yêu cầu HTTP đến URL cần kiểm tra.
                </li>

                <li>
                    <strong>Đo thời gian phản hồi:</strong>
                    hệ thống sử dụng bộ đếm thời gian để tính URL phản hồi trong bao nhiêu mili giây.
                </li>

                <li>
                    <strong>Ghi nhận HTTP Status Code:</strong>
                    ví dụ <code>200</code>, <code>301</code>, <code>302</code>, <code>403</code>, <code>404</code>,
                    <code>500</code> hoặc lỗi timeout.
                </li>

                <li>
                    <strong>Phân loại trạng thái:</strong>
                    dựa vào mã phản hồi và lỗi kết nối, hệ thống phân loại URL thành Online, Redirect, Client Error,
                    Server Error hoặc Offline.
                </li>

                <li>
                    <strong>Phân tích rủi ro:</strong>
                    hệ thống áp dụng các rule kiểm tra như HTTPS, từ khóa đáng ngờ, domain giả mạo thương hiệu,
                    ký tự Unicode bất thường, punycode, TLD rủi ro, cấu trúc URL và nhóm nội dung rủi ro cao
                    như cá cược/cờ bạc trực tuyến.
                </li>

                <li>
                    <strong>Lưu kết quả:</strong>
                    toàn bộ kết quả quét được lưu vào SQL Server để phục vụ việc xem lại lịch sử và thống kê.
                </li>
            </ol>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">3. Cách phân loại trạng thái hoạt động</h4>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Điều kiện</th>
                            <th>Trạng thái</th>
                            <th>Ý nghĩa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>HTTP 200 - 299</code></td>
                            <td><span class="badge bg-success">Online</span></td>
                            <td>URL phản hồi thành công và có thể truy cập được.</td>
                        </tr>
                        <tr>
                            <td><code>HTTP 300 - 399</code></td>
                            <td><span class="badge bg-primary">Redirect</span></td>
                            <td>URL có chuyển hướng sang một địa chỉ khác.</td>
                        </tr>
                        <tr>
                            <td><code>HTTP 400 - 499</code></td>
                            <td><span class="badge bg-warning text-dark">Client Error</span></td>
                            <td>URL tồn tại nhưng yêu cầu bị lỗi, ví dụ 403 Forbidden hoặc 404 Not Found.</td>
                        </tr>
                        <tr>
                            <td><code>HTTP 500 - 599</code></td>
                            <td><span class="badge bg-danger">Server Error</span></td>
                            <td>Máy chủ phản hồi lỗi phía server.</td>
                        </tr>
                        <tr>
                            <td>Timeout, DNS Error, Connection Error</td>
                            <td><span class="badge bg-danger">Offline</span></td>
                            <td>URL không phản hồi hoặc không thể kết nối.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">4. Cách tính điểm rủi ro</h4>

            <p>
                NetURLScanner sử dụng phương pháp <strong>rule-based scoring</strong>. Mỗi dấu hiệu bất thường sẽ được
                cộng một số điểm rủi ro. Tổng điểm tối đa là <strong>100 điểm</strong>. Điểm càng cao thì URL càng có
                nhiều dấu hiệu cần chú ý.
            </p>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nhóm rule</th>
                            <th>Dấu hiệu kiểm tra</th>
                            <th>Điểm cộng</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Bảo mật kết nối</td>
                            <td>URL không sử dụng HTTPS</td>
                            <td>+15</td>
                        </tr>
                        <tr>
                            <td>Trạng thái hoạt động</td>
                            <td>URL không phản hồi hoặc bị lỗi kết nối</td>
                            <td>+20</td>
                        </tr>
                        <tr>
                            <td>Chuyển hướng</td>
                            <td>URL trả về mã redirect như 301 hoặc 302</td>
                            <td>+10</td>
                        </tr>
                        <tr>
                            <td>Lỗi máy chủ</td>
                            <td>URL trả về lỗi nhóm 5xx</td>
                            <td>+15</td>
                        </tr>
                        <tr>
                            <td>Hiệu năng</td>
                            <td>Thời gian phản hồi lớn hơn 3 giây</td>
                            <td>+10</td>
                        </tr>
                        <tr>
                            <td>Hiệu năng</td>
                            <td>Thời gian phản hồi lớn hơn 7 giây</td>
                            <td>+15</td>
                        </tr>
                        <tr>
                            <td>Cấu trúc URL</td>
                            <td>URL quá dài, lớn hơn 100 ký tự</td>
                            <td>+10</td>
                        </tr>
                        <tr>
                            <td>Cấu trúc URL</td>
                            <td>Query string dài bất thường</td>
                            <td>+10</td>
                        </tr>
                        <tr>
                            <td>Cấu trúc domain</td>
                            <td>Domain có nhiều dấu gạch ngang</td>
                            <td>+10</td>
                        </tr>
                        <tr>
                            <td>Cấu trúc domain</td>
                            <td>Domain có quá nhiều subdomain</td>
                            <td>+15</td>
                        </tr>
                        <tr>
                            <td>Địa chỉ IP</td>
                            <td>URL sử dụng địa chỉ IP thay vì tên miền</td>
                            <td>+20</td>
                        </tr>
                        <tr>
                            <td>Port bất thường</td>
                            <td>URL sử dụng port không phổ biến như 8080, 4444</td>
                            <td>+10</td>
                        </tr>
                        <tr>
                            <td>Từ khóa đáng ngờ</td>
                            <td>URL chứa các từ như login, verify, account, bank, password, otp, token...</td>
                            <td>+8 mỗi từ</td>
                        </tr>
                        <tr>
                            <td>Đường dẫn nhạy cảm</td>
                            <td>Path chứa các từ như admin, wp-admin, phpmyadmin, shell, cmd...</td>
                            <td>+12 mỗi từ</td>
                        </tr>
                        <tr>
                            <td>Homograph Attack</td>
                            <td>Domain chứa ký tự Unicode bất thường</td>
                            <td>+30</td>
                        </tr>
                        <tr>
                            <td>Punycode</td>
                            <td>Domain chứa tiền tố <code>xn--</code></td>
                            <td>+25</td>
                        </tr>
                        <tr>
                            <td>Giả mạo thương hiệu</td>
                            <td>
                                Domain chứa hoặc gần giống thương hiệu uy tín nhưng không phải domain chính thức.
                                Danh sách thương hiệu gồm ngân hàng, ví điện tử, thương mại điện tử, chứng khoán,
                                dịch vụ công, vận chuyển và các nền tảng công nghệ phổ biến.
                            </td>
                            <td>+25 đến +35</td>
                        </tr>
                        <tr>
                            <td>Lookalike domain</td>
                            <td>Domain gần giống thương hiệu nổi tiếng, ví dụ <code>go0gle.com</code></td>
                            <td>+25 đến +30</td>
                        </tr>
                        <tr>
                            <td>Nội dung rủi ro cao</td>
                            <td>URL chứa từ khóa liên quan đến cá cược/cờ bạc như bet, betting, casino, gambling, nhà cái, tài xỉu, xóc đĩa...</td>
                            <td>+60</td>
                        </tr>
                        <tr>
                            <td>Rủi ro tài chính</td>
                            <td>URL cá cược/cờ bạc có liên quan đến đăng nhập, tài khoản, nạp tiền, rút tiền hoặc giao dịch tài chính</td>
                            <td>+20</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="alert alert-info mt-3">
                <strong>Lưu ý:</strong>
                hệ thống không khẳng định một URL chắc chắn độc hại. Kết quả chỉ là đánh giá rủi ro dựa trên các rule
                đã định nghĩa, giúp người dùng có thêm cơ sở để xem xét trước khi truy cập.
            </div>

            <div class="alert alert-warning mt-3">
                <strong>Lưu ý về nội dung cá cược/cờ bạc:</strong>
                Các URL có dấu hiệu liên quan đến cá cược/cờ bạc trực tuyến được hệ thống xếp vào nhóm rủi ro cao.
                Nhóm URL này có thể tiềm ẩn nguy cơ mất tài sản, lừa đảo tài chính, thu thập thông tin cá nhân
                hoặc dẫn dụ người dùng thực hiện giao dịch không an toàn.
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">5. Cách phân loại mức rủi ro</h4>

            <div class="row g-3 mt-2">
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h5><span class="badge bg-success">Safe</span></h5>
                        <p class="mb-1"><strong>0 - 30 điểm</strong></p>
                        <p class="text-muted mb-0">
                            URL có ít hoặc không có dấu hiệu bất thường. Đây là nhóm URL có mức rủi ro thấp.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h5><span class="badge bg-warning text-dark">Warning</span></h5>
                        <p class="mb-1"><strong>31 - 60 điểm</strong></p>
                        <p class="text-muted mb-0">
                            URL có một số dấu hiệu cần chú ý như redirect, response chậm, từ khóa nhạy cảm hoặc domain
                            có cấu trúc không bình thường.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h5><span class="badge bg-danger">Suspicious</span></h5>
                        <p class="mb-1"><strong>61 - 100 điểm</strong></p>
                        <p class="text-muted mb-0">
                            URL có nhiều dấu hiệu rủi ro như giả mạo thương hiệu, dùng ký tự thay thế, chứa từ khóa lừa đảo,
                            TLD rủi ro hoặc không phản hồi ổn định.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">6. Ví dụ minh họa</h4>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>URL</th>
                            <th>Phân tích</th>
                            <th>Kết quả dự kiến</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>https://google.com</code></td>
                            <td>Sử dụng HTTPS, domain chính thức, không có dấu hiệu bất thường.</td>
                            <td><span class="badge bg-success">Safe</span></td>
                        </tr>
                        <tr>
                            <td><code>https://go0gle.com</code></td>
                            <td>Dùng số 0 thay cho chữ o, gần giống thương hiệu Google.</td>
                            <td><span class="badge bg-warning text-dark">Warning</span></td>
                        </tr>
                        <tr>
                            <td><code>http://google-login-verify.xyz</code></td>
                            <td>Không dùng HTTPS, chứa thương hiệu Google, có từ login/verify và dùng TLD .xyz.</td>
                            <td><span class="badge bg-danger">Suspicious</span></td>
                        </tr>
                        <tr>
                            <td><code>https://google.com.verify-account.xyz</code></td>
                            <td>Chứa google.com trong subdomain nhưng domain thật là verify-account.xyz.</td>
                            <td><span class="badge bg-danger">Suspicious</span></td>
                        </tr>
                        <tr>
                            <td><code>http://192.168.1.20:8080/admin</code></td>
                            <td>Dùng IP thay domain, không dùng HTTPS, port lạ và có path admin.</td>
                            <td><span class="badge bg-danger">Suspicious</span></td>
                        </tr>
                        <tr>
                            <td><code>https://f8bet.vn</code></td>
                            <td>URL chứa từ khóa liên quan đến cá cược/cờ bạc. Đây là nhóm nội dung rủi ro cao, có thể tiềm ẩn nguy cơ mất tài sản hoặc lừa đảo tài chính.</td>
                            <td><span class="badge bg-danger">Suspicious</span></td>
                        </tr>
                        <tr>
                            <td><code>https://casino-online.xyz</code></td>
                            <td>URL chứa từ khóa casino và sử dụng TLD .xyz. Hệ thống đánh giá đây là URL có rủi ro cao.</td>
                            <td><span class="badge bg-danger">Suspicious</span></td>
                        </tr>
                        <tr>
                            <td><code>https://casino-login-payment.xyz</code></td>
                            <td>URL liên quan đến cá cược/cờ bạc, có từ khóa login/payment và dùng TLD rủi ro. Đây là trường hợp có nguy cơ liên quan đến tài khoản hoặc giao dịch tài chính.</td>
                            <td><span class="badge bg-danger">Suspicious</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">7. Danh sách thương hiệu uy tín dùng để đối chiếu</h4>

            <p>
                NetURLScanner sử dụng danh sách thương hiệu uy tín ở nhiều lĩnh vực phổ biến tại Việt Nam
                để phát hiện các tên miền có dấu hiệu giả mạo hoặc nhìn giống domain chính thức.
                Danh sách này không dùng để khẳng định một URL chắc chắn an toàn, mà dùng để phát hiện
                các trường hợp đáng ngờ như <code>vietcombank-login.xyz</code>,
                <code>momo-verify.top</code>, <code>shopee-gift.click</code> hoặc <code>paypa1.com</code>.
            </p>

            <div class="row g-3 mt-2">
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h6 class="fw-bold">Ngân hàng</h6>
                        <p class="text-muted mb-0">
                            Vietcombank, BIDV, VietinBank, Agribank, Techcombank, MB Bank, ACB,
                            Sacombank, VPBank, TPBank, VIB, HDBank, OCB, MSB, SHB...
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h6 class="fw-bold">Ví điện tử / thanh toán</h6>
                        <p class="text-muted mb-0">
                            MoMo, ZaloPay, VNPAY, Viettel Money và các cổng thanh toán phổ biến.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h6 class="fw-bold">Thương mại điện tử</h6>
                        <p class="text-muted mb-0">
                            Shopee, Lazada, Tiki, Sendo và các nền tảng mua sắm trực tuyến phổ biến.
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h6 class="fw-bold">Chứng khoán / tài chính</h6>
                        <p class="text-muted mb-0">
                            SSI, VNDirect, VPS, TCBS, HSC, VCBS, MBS, DNSE, FPTS...
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h6 class="fw-bold">Dịch vụ công</h6>
                        <p class="text-muted mb-0">
                            Cổng Dịch vụ công, Tổng cục Thuế, Thuế điện tử, Bảo hiểm xã hội,
                            VNeID, Ngân hàng Nhà nước Việt Nam...
                        </p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <h6 class="fw-bold">Nền tảng công nghệ / vận chuyển</h6>
                        <p class="text-muted mb-0">
                            Google, Facebook, Microsoft, Apple, GitHub, PayPal, Zalo, YouTube,
                            Viettel Post, GHN, GHTK, Grab...
                        </p>
                    </div>
                </div>
            </div>

            <div class="alert alert-secondary mt-3 mb-0">
                <strong>Lưu ý:</strong>
                danh sách thương hiệu có thể được mở rộng thêm theo nhu cầu thực tế.
                Khi cập nhật, cần ưu tiên lấy domain chính thức từ website của tổ chức,
                cơ quan quản lý, trang giới thiệu chính thức hoặc các nguồn đáng tin cậy.
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold">8. Công nghệ, ngôn ngữ và công cụ sử dụng</h4>

            <p>
                Dự án NetURLScanner được xây dựng theo mô hình ứng dụng web MVC, sử dụng các công nghệ phổ biến trong
                hệ sinh thái .NET và SQL Server.
            </p>

            <div class="row g-3 mt-2">
                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
