@{
    ViewData["Title"] = "Không tìm thấy trang";
}

<div class="container text-center mt-5 pt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="display-1 fw-bold text-primary mb-0">404</h1>
            <h3 class="fw-bold mb-3">Oops! Không tìm thấy trang này.</h3>
            
            <p class="text-muted mb-4 text-center">
                Có vẻ như URL bạn đang cố truy cập không tồn tại hoặc đã bị di dời.
                Hãy kiểm tra lại đường dẫn hoặc quay về trang chủ để tiếp tục sử dụng hệ thống NetURLScanner.
            </p>

            <a asp-controller="UrlScanner" asp-action="Index" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">
                Quay lại Trang chủ
            </a>
            
            <a asp-controller="UrlScanner" asp-action="History" class="btn btn-outline-secondary btn-lg px-4 rounded-pill ms-2 shadow-sm">
                Xem Lịch sử quét
            </a>
        </div>
    </div>
</div>
