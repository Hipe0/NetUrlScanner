@model NetURLScanner.Models.UrlScan

@{
    ViewData["Title"] = "Chi tiết quét URL";

    bool isGamblingUrl =
        !string.IsNullOrEmpty(Model.Reasons)
        && (Model.Reasons.Contains("cá cược", StringComparison.OrdinalIgnoreCase)
            || Model.Reasons.Contains("cờ bạc", StringComparison.OrdinalIgnoreCase));

    string riskDisplayName = Model.RiskLevel switch
    {
        "Safe" => "Safe - An toàn",
        "Warning" => "Warning - Cần chú ý",
        "Suspicious" => "Suspicious - Nguy hiểm",
        _ => Model.RiskLevel
    };

    string badgeClass = Model.RiskLevel switch
    {
        "Safe" => "bg-success",
        "Warning" => "bg-warning text-dark",
        "Suspicious" => "bg-danger",
        _ => "bg-secondary"
    };

    int progressValue = Math.Clamp(Model.RiskScore, 0, 100);

    string progressClass = Model.RiskLevel switch
    {
        "Safe" => "bg-success",
        "Warning" => "bg-warning",
        "Suspicious" => "bg-danger",
        _ => "bg-secondary"
    };

    string statusClass = Model.Status switch
    {
        "Online" => "text-success",
        "Redirect" => "text-primary",
        "Client Error" => "text-warning",
        "Server Error" => "text-danger",
        "Offline" => "text-danger",
        _ => "text-muted"
    };

    var reasons = string.IsNullOrWhiteSpace(Model.Reasons)
        ? new List<string>()
        : Model.Reasons
            .Split(";", StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">Báo cáo phân tích URL</h2>
        <p class="text-muted mb-0">
            Chi tiết trạng thái hoạt động, điểm rủi ro và các lý do hệ thống đánh giá URL.
        </p>
    </div>

    @if (isGamblingUrl)
    {
        <div class="alert alert-danger shadow-sm border-0 mb-4">
            <h5 class="alert-heading fw-bold mb-2">Cảnh báo nội dung rủi ro cao</h5>
            <p class="mb-0">
                URL này có dấu hiệu liên quan đến cá cược/cờ bạc trực tuyến. Đây là nhóm nội dung rủi ro cao,
                có thể tiềm ẩn nguy cơ mất tài sản, lừa đảo tài chính, thu thập thông tin cá nhân
                hoặc dẫn dụ người dùng thực hiện giao dịch không an toàn.
            </p>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="row g-4 align-items-center">
                <!-- Cột trái: SVG Circular Gauge -->
                <div class="col-md-4 text-center">
                    <div class="gauge-wrapper">
                        <svg viewBox="0 0 100 100" class="gauge-svg">
                            <circle cx="50" cy="50" r="45" class="gauge-bg"></circle>
                            <circle cx="50" cy="50" r="45" class="gauge-fill" id="detailsGaugeCircle"></circle>
                        </svg>
                        <div class="gauge-text">
                            <span class="gauge-value text-body" id="detailsGaugeVal">0</span>
                            <span class="gauge-percent">%</span>
                            <div class="gauge-label" id="detailsGaugeLabel">Đang tính</div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="badge @badgeClass fs-6 px-3 py-2">
                            @riskDisplayName
                        </span>
                    </div>
                </div>

                <!-- Cột phải: URL và chi tiết -->
                <div class="col-md-8">
                    <div class="mb-3">
                        <p class="text-muted mb-1">URL đã quét</p>
                        <h5 class="fw-bold mb-0 text-primary" style="word-break: break-all;">
                            @Model.Url
                        </h5>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 col-lg-3">
                            <div class="border rounded p-3 bg-body-tertiary">
                                <p class="text-muted mb-1 small">Trạng thái</p>
                                <h6 class="mb-0 fw-bold @statusClass">@Model.Status</h6>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <div class="border rounded p-3 bg-body-tertiary">
                                <p class="text-muted mb-1 small">HTTP Code</p>
                                <h6 class="mb-0 fw-bold">@(Model.StatusCode?.ToString() ?? "-")</h6>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <div class="border rounded p-3 bg-body-tertiary">
                                <p class="text-muted mb-1 small">Phản hồi</p>
                                <h6 class="mb-0 fw-bold">@Model.ResponseTimeMs ms</h6>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-3">
                            <div class="border rounded p-3 bg-body-tertiary">
                                <p class="text-muted mb-1 small">HTTPS</p>
                                @if (Model.IsHttps)
                                {
                                    <h6 class="mb-0 fw-bold text-success">Có</h6>
                                }
                                else
                                {
                                    <h6 class="mb-0 fw-bold text-danger">Không</h6>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mt-3 mb-0 py-2 small">
                            <strong>Lỗi kết nối:</strong> @Model.ErrorMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Khung kết quả chi tiết & Bản đồ máy chủ địa lý -->
    <div class="row g-4 mb-4">
        <!-- Cột trái: Lý do đánh giá -->
        <div id="detailsReasonsCol" class="col-lg-6 d-flex flex-column">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <h5 class="fw-bold mb-0 text-primary">Lý do đánh giá</h5>
                        <span class="badge @badgeClass fs-6 px-3 py-1">
                            @Model.RiskScore điểm
                        </span>
                    </div>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                    <p class="text-muted small mb-3">Các dấu hiệu bất thường hoặc an toàn được phát hiện sau khi phân tích:</p>
                    <div class="flex-grow-1 overflow-y-auto" style="max-height: 380px;">
                        @if (reasons.Any())
                        {
                            <ul class="list-group list-group-flush mb-0">
                                @foreach (var reason in reasons)
                                {
                                    bool isDangerReason =
                                        reason.Contains("cá cược", StringComparison.OrdinalIgnoreCase)
                                        || reason.Contains("cờ bạc", StringComparison.OrdinalIgnoreCase)
                                        || reason.Contains("mất tài sản", StringComparison.OrdinalIgnoreCase)
                                        || reason.Contains("lừa đảo", StringComparison.OrdinalIgnoreCase);

                                    <li class="list-group-item d-flex align-items-start gap-2 px-0 bg-transparent py-2 border-0">
                                        @if (isDangerReason)
                                        {
                                            <span class="badge bg-danger mt-1">!</span>
                                        }
                                        else if (Model.RiskLevel == "Safe")
                                        {
                                            <span class="badge bg-success mt-1">✓</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark mt-1">!</span>
                                        }

                                        <span>@reason</span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-muted text-center py-4">
                                Không có lý do đánh giá được ghi nhận.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Bản đồ máy chủ địa lý -->
        <div id="detailsMapCol" class="col-lg-6 d-flex flex-column">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0 text-primary">Bản đồ vị trí máy chủ</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column">
                    <div class="p-3 border rounded-3 bg-body-tertiary mb-3 text-start">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <span class="text-muted d-block small mb-1">
                                    <i class="bi bi-hdd-network text-primary me-1"></i> Địa chỉ IP máy chủ:
                                </span>
                                <span class="fw-bold font-monospace">@(Model.IpAddress ?? "-")</span>
                            </div>
                            <div class="col-sm-6">
                                <span class="text-muted d-block small mb-1">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i> Vị trí địa lý:
                                </span>
                                <span class="fw-bold text-primary">
                                    @if (!string.IsNullOrEmpty(Model.CountryCode) && Model.CountryCode != "-")
                                    {
                                        string flag = "";
                                        try {
                                            string code = Model.CountryCode.ToUpper();
                                            int val1 = 127397 + code[0];
                                            int val2 = 127397 + code[1];
                                            flag = char.ConvertFromUtf32(val1) + char.ConvertFromUtf32(val2) + " ";
                                        } catch {}
                                        @flag
                                    }
                                    @Model.City, @Model.CountryName
                                </span>
                            </div>
                            <div class="col-12 mt-2 pt-2 border-top">
                                <span class="text-muted d-block small mb-1">
                                    <i class="bi bi-broadcast text-success me-1"></i> Nhà mạng quản lý (ISP):
                                </span>
                                <span class="fw-bold">@(Model.Isp ?? "-")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Bản đồ Leaflet -->
                    <div class="leaflet-map-card flex-grow-1 d-flex">
                        <div id="detailsMap" class="leaflet-map-div h-100 flex-grow-1" style="min-height: 260px;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
        <p class="text-muted mb-0">
            Thời gian quét: @Model.ScannedAt.ToString("dd/MM/yyyy HH:mm:ss")
        </p>

        <div>
            <a asp-action="Index" class="btn btn-secondary">
                Quay lại
            </a>

            <a asp-action="History" class="btn btn-outline-primary">
                Xem lịch sử
            </a>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // 1. Hoạt ảnh Gauge rủi ro
            const score = @Model.RiskScore;
            const level = '@Model.RiskLevel';
            
            const circle = document.getElementById('detailsGaugeCircle');
            const valText = document.getElementById('detailsGaugeVal');
            const labelText = document.getElementById('detailsGaugeLabel');
            if (circle && valText) {
                circle.className = 'gauge-fill';
                if (level === 'Safe') circle.classList.add('gauge-safe');
                else if (level === 'Warning') circle.classList.add('gauge-warning');
                else circle.classList.add('gauge-danger');

                if (labelText) {
                    labelText.textContent = level === 'Safe' ? 'An toàn' : 
                                           level === 'Warning' ? 'Cảnh báo' : 'Nguy hiểm';
                }

                const r = 45;
                const circumference = 2 * Math.PI * r;
                
                circle.style.strokeDasharray = circumference;
                circle.style.strokeDashoffset = circumference;

                setTimeout(() => {
                    const offset = circumference - (score / 100) * circumference;
                    circle.style.strokeDashoffset = offset;
                }, 100);

                let startTimestamp = null;
                const duration = 1000;
                
                function step(timestamp) {
                    if (!startTimestamp) startTimestamp = timestamp;
                    const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    const easeProgress = progress * (2 - progress);
                    const currentVal = Math.round(easeProgress * score);
                    valText.textContent = currentVal;
                    
                    if (progress < 1) {
                        window.requestAnimationFrame(step);
                    }
                }
                window.requestAnimationFrame(step);
            }

            // 2. Khởi tạo bản đồ máy chủ Leaflet
            const lat = @(Model.Latitude?.ToString() ?? "null");
            const lon = @(Model.Longitude?.ToString() ?? "null");
            const ip = '@Html.Raw(Model.IpAddress)';
            const country = '@Html.Raw(Model.CountryName)';

            if (lat && lon) {
                let detailsMapObj = null;

                function initDetailsMap() {
                    const mapContainer = document.getElementById('detailsMap');
                    if (!mapContainer) return;

                    if (detailsMapObj) {
                        detailsMapObj.remove();
                        detailsMapObj = null;
                    }

                    detailsMapObj = L.map('detailsMap').setView([lat, lon], 12);

                    const currentTheme = document.documentElement.getAttribute('data-bs-theme');
                    let tileUrl = 'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png';
                    if (currentTheme === 'dark') {
                        tileUrl = 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png';
                    }

                    L.tileLayer(tileUrl, {
                        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                    }).addTo(detailsMapObj);

                    L.marker([lat, lon]).addTo(detailsMapObj)
                        .bindPopup(`<b>IP:</b> ${ip}<br><b>Quốc gia:</b> ${country}`)
                        .openPopup();
                }

                // Khởi tạo
                initDetailsMap();

                // Lắng nghe nút đổi màu giao diện (Theme) để cập nhật màu bản đồ
                document.getElementById('themeToggle')?.addEventListener('click', () => {
                    setTimeout(initDetailsMap, 100);
                });
            } else {
                // Ẩn khối bản đồ nếu không phân giải được vị trí
                const mapCol = document.getElementById('detailsMapCol');
                if (mapCol) {
                    mapCol.classList.add('d-none');
                    // Mở rộng khung lý do đánh giá chiếm trọn chiều rộng nếu không có bản đồ
                    const reasonsCol = document.getElementById('detailsReasonsCol');
                    if (reasonsCol) {
                        reasonsCol.className = 'col-12';
                    }
                }
            }
        });
    </script>
}