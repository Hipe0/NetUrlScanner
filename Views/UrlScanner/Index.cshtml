@model List<NetURLScanner.Models.UrlScan>

@{
    ViewData["Title"] = "NetURLScanner";

    var total = Model.Count;
    var online = Model.Count(x => x.Status == "Online");
    var warning = Model.Count(x => x.RiskLevel == "Warning");
    var suspicious = Model.Count(x => x.RiskLevel == "Suspicious");
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">NetURLScanner</h2>
        <p class="text-muted">
            Hệ thống quét URL, kiểm tra trạng thái hoạt động và đánh giá rủi ro giả mạo.
        </p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Total Scans</p>
                    <h3 class="fw-bold">@total</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Online</p>
                    <h3 class="fw-bold text-success">@online</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Warning</p>
                    <h3 class="fw-bold text-warning">@warning</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Suspicious</p>
                    <h3 class="fw-bold text-danger">@suspicious</h3>
                </div>
            </div>
        </div>
    </div>



    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form id="scanForm" onsubmit="return false;">
                @Html.AntiForgeryToken()

                <label class="form-label fw-semibold">Nhập URL cần quét</label>

                <div class="input-group">
                    <input type="text"
                           name="url"
                           id="urlInput"
                           class="form-control"
                           placeholder="Ví dụ: google.com, go0gle.com, https://github.com"
                           required />

                    <button type="button" id="scanButton" class="btn btn-primary px-4">
                        <span id="buttonSpinner" class="spinner-border spinner-border-sm d-none me-1" role="status" aria-hidden="true"></span>
                        <span id="buttonText">Scan</span>
                    </button>
                </div>

                <small class="text-muted">
                    Hệ thống sẽ kiểm tra HTTP status, HTTPS, response time, keyword, domain giả mạo và TLD rủi ro.
                </small>
            </form>
        </div>
    </div>

    <!-- Hộp thoại Loading Tiến trình quét (5 bước) -->
    <div id="loadingSection" class="card shadow-sm border-0 mb-4 d-none">
        <div class="card-body py-4">
            <h5 class="fw-bold mb-3 d-flex align-items-center">
                <span class="spinner-border spinner-border-sm text-primary me-2" role="status"></span>
                <span>Đang phân tích URL: </span>
                <span id="scanningUrlText" class="ms-1 text-primary text-break-all"></span>
            </h5>
            <div class="loading-steps ps-2">
                <div id="step-1" class="loading-step mb-3 text-muted">
                    <i class="bi bi-circle me-2"></i>
                    <span>Bước 1: Chuẩn hóa và định dạng cấu trúc URL...</span>
                </div>
                <div id="step-2" class="loading-step mb-3 text-muted">
                    <i class="bi bi-circle me-2"></i>
                    <span>Bước 2: Gửi yêu cầu HTTP và kiểm tra phản hồi máy chủ...</span>
                </div>
                <div id="step-3" class="loading-step mb-3 text-muted">
                    <i class="bi bi-circle me-2"></i>
                    <span>Bước 3: Tra cứu cơ sở dữ liệu Whitelist và Blacklist...</span>
                </div>
                <div id="step-4" class="loading-step mb-3 text-muted">
                    <i class="bi bi-circle me-2"></i>
                    <span>Bước 4: Chạy bộ lọc Heuristics phát hiện từ khóa lừa đảo...</span>
                </div>
                <div id="step-5" class="loading-step mb-0 text-muted">
                    <i class="bi bi-circle me-2"></i>
                    <span>Bước 5: Định vị địa lý máy chủ & hoàn tất báo cáo...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Thẻ Kết quả Phân tích Nhanh AJAX -->
    <div id="ajaxResultCard" class="card shadow-sm border-0 mb-4 d-none slide-down-enter">
        <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0 text-primary">Kết quả phân tích nhanh</h4>
                <a id="resultDetailLink" href="#" class="btn btn-outline-primary btn-sm">
                    Xem báo cáo đầy đủ <i class="bi bi-arrow-right-short"></i>
                </a>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <!-- Cột trái: Đồng hồ, thông tin hạ tầng & Bản đồ -->
                <div class="col-lg-6 d-flex flex-column">
                    <div class="row g-3 align-items-center mb-3">
                        <div class="col-sm-5 text-center">
                            <div class="gauge-wrapper">
                                <svg viewBox="0 0 100 100" class="gauge-svg">
                                    <circle cx="50" cy="50" r="45" class="gauge-bg"></circle>
                                    <circle cx="50" cy="50" r="45" class="gauge-fill" id="ajaxGaugeCircle"></circle>
                                </svg>
                                <div class="gauge-text">
                                    <span class="gauge-value text-body" id="ajaxGaugeVal">0</span>
                                    <span class="gauge-percent">%</span>
                                    <div class="gauge-label" id="ajaxGaugeLabel">Đang tính</div>
                                </div>
                            </div>
                            <div class="mt-2">
                                <span id="ajaxRiskBadge" class="badge px-3 py-2">Đang phân tích</span>
                            </div>
                        </div>
                        <div class="col-sm-7">
                            <div class="p-3 border rounded-3 bg-body-tertiary">
                                <div class="mb-2">
                                    <span class="text-muted d-block small">Trạng thái</span>
                                    <span id="ajaxStatusText" class="fw-bold">Đang quét...</span>
                                    <span id="ajaxStatusCodeText" class="badge bg-secondary ms-1">-</span>
                                </div>
                                <div class="mb-2">
                                    <span class="text-muted d-block small">Phản hồi &amp; HTTPS</span>
                                    <span id="ajaxResponseTimeText" class="fw-bold">- ms</span>
                                    <span id="ajaxHttpsText" class="badge ms-1">-</span>
                                </div>
                                <div>
                                    <span class="text-muted d-block small">IP &amp; Nhà mạng (ISP)</span>
                                    <span id="ajaxIpText" class="fw-bold text-break-all">-</span>
                                    <div class="small text-muted" id="ajaxIspText">-</div>
                                    <div class="small fw-semibold mt-1 text-primary" id="ajaxLocationText">-</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Leaflet Map Wrapper -->
                    <div class="leaflet-map-card flex-grow-1 d-flex">
                        <div id="ajaxMap" class="leaflet-map-div h-100 flex-grow-1" style="min-height: 250px;"></div>
                    </div>
                </div>

                <!-- Cột phải: Đánh giá chi tiết của hệ thống -->
                <div class="col-lg-6 d-flex flex-column">
                    <div class="card border rounded-3 bg-body-tertiary h-100 shadow-sm">
                        <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                            <h5 class="fw-bold mb-0 text-primary">Đánh giá chi tiết từ hệ thống</h5>
                        </div>
                        <div class="card-body p-4 d-flex flex-column">
                            <p class="text-muted small mb-3">Các dấu hiệu bất thường hoặc an toàn được phát hiện sau khi phân tích:</p>
                            <ul id="ajaxReasonsList" class="list-group list-group-flush flex-grow-1 overflow-y-auto mb-0" style="max-height: 280px; font-size: 0.95rem;">
                                <!-- Lý do đổ từ JS -->
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="fw-bold mb-0">Lịch sử quét gần đây</h4>
        <a asp-action="History" class="btn btn-outline-secondary btn-sm">
            Xem tất cả
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>URL</th>
                        <th>Status</th>
                        <th>HTTP</th>
                        <th>Time</th>
                        <th>Risk</th>
                        <th>Scanned At</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        string badgeClass = item.RiskLevel switch
                        {
                            "Safe" => "bg-success",
                            "Warning" => "bg-warning text-dark",
                            "Suspicious" => "bg-danger",
                            _ => "bg-secondary"
                        };

                        string statusClass = item.Status switch
                        {
                            "Online" => "text-success fw-semibold",
                            "Redirect" => "text-primary fw-semibold",
                            "Client Error" => "text-warning fw-semibold",
                            "Server Error" => "text-danger fw-semibold",
                            "Offline" => "text-danger fw-semibold",
                            _ => "text-muted"
                        };

                        <tr>
                            <td class="text-break-all" style="max-width: 520px; word-break: break-all;">
                                @item.Url
                            </td>

                            <td class="@statusClass">
                                @item.Status
                            </td>

                            <td>@(item.StatusCode?.ToString() ?? "-")</td>

                            <td>@item.ResponseTimeMs ms</td>

                            <td>
                                <span class="badge @badgeClass">
                                    @item.RiskLevel (@item.RiskScore)
                                </span>
                            </td>

                            <td>
                                @item.ScannedAt.ToString("dd/MM/yyyy HH:mm:ss")
                            </td>

                            <td>
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Chi tiết
                                </a>
                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa kết quả này?');">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Xóa
                                </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="preconnect" href="https://s0.wp.com" crossorigin />
    <link rel="dns-prefetch" href="https://s0.wp.com" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="~/js/scan-page.js" asp-append-version="true"></script>
}