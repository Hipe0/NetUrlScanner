@model List<NetURLScanner.Models.UrlScan>

@{
    ViewData["Title"] = "NetURLScanner";

    var total = Model.Count;
    var online = Model.Count(x => x.Status == "Online");
    var warning = Model.Count(x => x.RiskLevel == "Warning");
    var suspicious = Model.Count(x => x.RiskLevel == "Suspicious");
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">NetURLScanner</h2>
        <p class="text-muted">
            Hệ thống quét URL, kiểm tra trạng thái hoạt động và đánh giá rủi ro giả mạo.
        </p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Total Scans</p>
                    <h3 class="fw-bold">@total</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Online</p>
                    <h3 class="fw-bold text-success">@online</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Warning</p>
                    <h3 class="fw-bold text-warning">@warning</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <p class="text-muted mb-1">Suspicious</p>
                    <h3 class="fw-bold text-danger">@suspicious</h3>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="Scan" method="post">
                @Html.AntiForgeryToken()

                <label class="form-label fw-semibold">Nhập URL cần quét</label>

                <div class="input-group">
                    <input type="text"
                           name="url"
                           class="form-control"
                           placeholder="Ví dụ: google.com, go0gle.com, https://github.com"
                           required />

                    <button type="submit" class="btn btn-primary px-4">
                        Scan
                    </button>
                </div>

                <small class="text-muted">
                    Hệ thống sẽ kiểm tra HTTP status, HTTPS, response time, keyword, domain giả mạo và TLD rủi ro.
                </small>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4 class="fw-bold mb-0">Lịch sử quét gần đây</h4>
        <a asp-action="History" class="btn btn-outline-secondary btn-sm">
            Xem tất cả
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>URL</th>
                        <th>Status</th>
                        <th>HTTP</th>
                        <th>Time</th>
                        <th>Risk</th>
                        <th>Scanned At</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        string badgeClass = item.RiskLevel switch
                        {
                            "Safe" => "bg-success",
                            "Warning" => "bg-warning text-dark",
                            "Suspicious" => "bg-danger",
                            _ => "bg-secondary"
                        };

                        string statusClass = item.Status switch
                        {
                            "Online" => "text-success fw-semibold",
                            "Redirect" => "text-primary fw-semibold",
                            "Client Error" => "text-warning fw-semibold",
                            "Server Error" => "text-danger fw-semibold",
                            "Offline" => "text-danger fw-semibold",
                            _ => "text-muted"
                        };

                        <tr>
                            <td style="max-width: 520px; word-break: break-all;">
                                @item.Url
                            </td>

                            <td class="@statusClass">
                                @item.Status
                            </td>

                            <td>@(item.StatusCode?.ToString() ?? "-")</td>

                            <td>@item.ResponseTimeMs ms</td>

                            <td>
                                <span class="badge @badgeClass">
                                    @item.RiskLevel (@item.RiskScore)
                                </span>
                            </td>

                            <td>
                                @item.ScannedAt.ToString("dd/MM/yyyy HH:mm:ss")
                            </td>

                            <td>
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Chi tiết
                                </a>
                                <form asp-action="Delete"
                                      asp-route-id="@item.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa kết quả này?');">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    Xóa
                                </button>
                                </form>
                            </td>
                            
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>