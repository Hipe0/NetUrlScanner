@{
    ViewData["Title"] = "Đăng ký";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-success text-white text-center py-4">
                    <h3 class="font-weight-light my-0"><i class="bi bi-person-plus"></i> Đăng Ký Tài Khoản</h3>
                </div>
                <div class="card-body p-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Register" method="post">
                        <div class="form-floating mb-3">
                            <input class="form-control" id="inputEmail" type="email" name="email" placeholder="name@example.com" required />
                            <label for="inputEmail">Địa chỉ Email</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control" id="inputPassword" type="password" name="password" placeholder="Mật khẩu" required />
                            <label for="inputPassword">Mật khẩu</label>
                        </div>
                        <div class="form-floating mb-4">
                            <input class="form-control" id="inputConfirmPassword" type="password" name="confirmPassword" placeholder="Xác nhận mật khẩu" required />
                            <label for="inputConfirmPassword">Xác nhận mật khẩu</label>
                        </div>
                        
                        <div class="d-flex align-items-center justify-content-center mt-4 mb-0">
                            <button class="btn btn-success px-5 py-2 w-100" type="submit">Đăng Ký</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3 bg-light">
                    <div class="small"><a asp-action="Login" class="text-decoration-none">Đã có tài khoản? Quay lại đăng nhập</a></div>
                </div>
            </div>
        </div>
    </div>
</div>
