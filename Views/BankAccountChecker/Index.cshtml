@model List<NetURLScanner.Models.ScamReport>

@{
    ViewData["Title"] = "Kiểm tra Tài khoản Ngân hàng";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 feature-hero-card mb-4">
            <div class="card-header bg-danger text-white text-center py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-bank me-2"></i>Tra cứu Blacklist Ngân hàng</h4>
            </div>
            <div class="card-body p-4">
                <p class="text-muted text-center mb-4">
                    Kiểm tra số tài khoản có trong danh sách báo cáo lừa đảo đã được duyệt trên hệ thống.
                </p>

                @if (User?.Identity?.IsAuthenticated != true)
                {
                    <div class="text-center py-4">
                        <i class="bi bi-lock-fill text-muted mb-3 d-block fs-1" aria-hidden="true"></i>
                        <h5 class="fw-bold mb-2">Yêu cầu đăng nhập</h5>
                        <p class="text-muted mb-4">Đăng nhập và nâng cấp Premium để tra cứu blacklist ngân hàng.</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/BankAccountChecker" class="btn btn-primary fw-bold px-4">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </a>
                    </div>
                }
                else
                {
                    <form asp-action="Index" method="post" id="checkForm">
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">@ViewBag.Error</div>
                        }

                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label fw-bold" for="bankSelect">Ngân hàng</label>
                                <select name="bankId" class="form-select" id="bankSelect" required>
                                    <option value="">-- Chọn ngân hàng --</option>
                                    <option value="OTHER">Khác (Tự nhập)</option>
                                </select>
                                <input type="text" name="customBankName" id="customBankInput" class="form-control mt-2 d-none" placeholder="Nhập tên ngân hàng" />
                            </div>
                            <div class="col-md-7">
                                <label class="form-label fw-bold" for="bankAccountInput">Số tài khoản</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-body-secondary"><i class="bi bi-123" aria-hidden="true"></i></span>
                                    <input type="text" name="bankAccountNumber" id="bankAccountInput" value="@ViewBag.BankAccountNumber" class="form-control" placeholder="Nhập số tài khoản" required inputmode="numeric" />
                                    <button type="submit" class="btn btn-danger fw-bold px-4">Kiểm tra</button>
                                </div>
                            </div>
                        </div>
                    </form>
                }
            </div>
        </div>

        @if (ViewBag.HasSearched == true)
        {
            var blacklistMatch = ViewBag.BlacklistMatch as NetURLScanner.Models.BlacklistedBankAccount;
            
            if (blacklistMatch != null)
            {
                <div class="alert alert-danger shadow-sm mb-4" role="alert">
                    <h4 class="alert-heading fw-bold"><i class="bi bi-shield-x me-2"></i>NẰM TRONG DANH SÁCH ĐEN!</h4>
                    <p>Số tài khoản <strong>@ViewBag.BankAccountNumber</strong> đã bị hệ thống đưa vào <strong>danh sách đen chính thức</strong>.</p>
                    <p class="mb-1 mt-2"><strong>Lý do:</strong> @blacklistMatch.Reason</p>
                    <hr>
                    <p class="mb-0"><strong>Tuyệt đối không</strong> chuyển tiền vào tài khoản này.</p>
                </div>
            }

            if (Model != null && Model.Any())
            {
                @if (blacklistMatch == null)
                {
                    <div class="alert alert-danger shadow-sm mb-4" role="alert">
                        <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Cảnh báo nguy hiểm</h4>
                        <p class="mb-2">Số tài khoản <strong>@ViewBag.BankAccountNumber</strong> đã bị báo cáo lừa đảo <strong>@Model.Count</strong> lần.</p>
                        <hr>
                        <p class="mb-0">Vui lòng <strong>TUYỆT ĐỐI KHÔNG</strong> thực hiện giao dịch chuyển tiền vào số tài khoản này.</p>
                    </div>
                }

                <h5 class="fw-bold mb-3 mt-4">Danh sách các báo cáo từ cộng đồng:</h5>
                <div class="list-group shadow-sm">
                    @foreach (var report in Model)
                    {
                        <div class="list-group-item">
                            <div class="d-flex w-100 justify-content-between gap-2 flex-wrap">
                                <h6 class="mb-1 fw-bold text-danger">@(string.IsNullOrEmpty(report.BankAccountOwnerName) ? "Không rõ chủ TK" : report.BankAccountOwnerName)</h6>
                                <small class="text-muted">@report.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <p class="mb-1 mt-2"><strong>Nội dung:</strong> @report.Evidence</p>
                            @if (report.AmountLost > 0)
                            {
                                <small class="text-danger fw-bold">Thiệt hại: @string.Format("{0:N0}", report.AmountLost) VNĐ</small>
                            }
                        </div>
                    }
                </div>
            }
            else if (blacklistMatch == null)
            {
                <div class="alert alert-success shadow-sm" role="status">
                    <h4 class="alert-heading fw-bold"><i class="bi bi-check-circle-fill me-2"></i>Chưa có báo cáo</h4>
                    <p class="mb-2">Chưa ghi nhận báo cáo lừa đảo cho số <strong>@ViewBag.BankAccountNumber</strong> trên hệ thống.</p>
                    <hr>
                    <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Lưu ý: Kết quả này chỉ dựa trên dữ liệu hiện tại trên NetURLScanner. Bạn vẫn nên cẩn trọng khi giao dịch với người lạ.</small>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/bank-select.js" asp-append-version="true" defer></script>
    <script defer>
        document.addEventListener('DOMContentLoaded', () => {
            window.BankSelect?.init({
                selectId: 'bankSelect',
                customInputId: 'customBankInput',
                selectedBankId: '@Html.Raw(ViewBag.BankId ?? "")',
                otherCustomValue: '@Html.Raw(ViewBag.BankId ?? "")'
            });
        });
    </script>
}
