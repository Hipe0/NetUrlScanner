@{
    ViewData["Title"] = "Quản trị nội dung";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2"></i>Quản trị nội dung (CMS)</h2>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="fw-bold">Trang Giới thiệu</h5>
                    <p class="text-muted small">Chỉnh sửa phần mở đầu hiển thị trên trang Giới thiệu.</p>
                    <a asp-action="EditIntroduction" class="btn btn-primary btn-sm">Chỉnh sửa</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="fw-bold">Câu hỏi thường gặp (FAQ)</h5>
                    <p class="text-muted small">Thêm, sửa, xóa các câu hỏi FAQ cho người dùng.</p>
                    <a asp-action="FaqList" class="btn btn-primary btn-sm">Quản lý FAQ</a>
                </div>
            </div>
        </div>
    </div>
</div>
