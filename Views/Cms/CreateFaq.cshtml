@model NetURLScanner.Models.FaqItem
@{
    ViewData["Title"] = "Thêm FAQ";
}

<div class="container mt-4" style="max-width:720px;">
    <h2 class="fw-bold mb-4">Thêm câu hỏi FAQ</h2>
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="CreateFaq" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Question" class="form-label fw-semibold">Câu hỏi</label>
                    <input asp-for="Question" class="form-control" />
                    <span asp-validation-for="Question" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Answer" class="form-label fw-semibold">Câu trả lời</label>
                    <textarea asp-for="Answer" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Answer" class="text-danger small"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="SortOrder" class="form-label fw-semibold">Thứ tự hiển thị</label>
                        <input asp-for="SortOrder" type="number" class="form-control" value="0" />
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" checked />
                            <label asp-for="IsActive" class="form-check-label">Hiển thị trên trang FAQ</label>
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Thêm</button>
                <a asp-action="FaqList" class="btn btn-outline-secondary ms-2">Hủy</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
