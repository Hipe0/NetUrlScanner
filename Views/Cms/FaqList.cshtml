@model IEnumerable<NetURLScanner.Models.FaqItem>
@{
    ViewData["Title"] = "Quản lý FAQ";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-question-circle me-2"></i>Quản lý FAQ</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← CMS</a>
            <a asp-action="CreateFaq" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Thêm câu hỏi</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px;">STT</th>
                        <th>Câu hỏi</th>
                        <th style="width:100px;">Hiển thị</th>
                        <th style="width:180px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SortOrder</td>
                            <td>@item.Question</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Bật</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tắt</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditFaq" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                <form asp-action="DeleteFaq" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa câu hỏi này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
