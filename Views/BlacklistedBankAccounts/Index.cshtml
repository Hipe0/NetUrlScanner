@model IEnumerable<NetURLScanner.Models.BlacklistedBankAccount>

@{
    ViewData["Title"] = "Quản lý Blacklist Ngân hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-bank me-2 text-danger"></i>Quản lý Blacklist Ngân hàng</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Thêm số tài khoản
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ngân hàng</th>
                        <th>Số tài khoản</th>
                        <th>Chủ tài khoản</th>
                        <th>Lý do</th>
                        <th>Ngày thêm</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                Chưa có số tài khoản nào trong blacklist.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@item.BankId</span></td>
                                <td><strong class="text-danger">@item.BankAccountNumber</strong></td>
                                <td>@item.BankAccountOwnerName</td>
                                <td>@item.Reason</td>
                                <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @if (item.IsActive)
                                        {
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3" title="Bấm để tắt">
                                                <i class="bi bi-check-circle me-1"></i>Đang chặn
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-secondary rounded-pill px-3" title="Bấm để bật">
                                                <i class="bi bi-dash-circle me-1"></i>Tạm dừng
                                            </button>
                                        }
                                    </form>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa số tài khoản này khỏi blacklist?');">
                                            <button type="submit" class="btn btn-outline-danger" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
