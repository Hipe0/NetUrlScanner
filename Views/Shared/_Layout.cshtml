<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NetURLScanner</title>

    <!-- Khởi tạo Dark Mode từ localStorage trước khi render HTML để không bị chớp màn hình -->
    <script>
            const storedTheme = localStorage.getItem('theme');

            const getPreferredTheme = () => {
                if (storedTheme) {
                    return storedTheme;
                }

                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            };

            document.documentElement.setAttribute('data-bs-theme', getPreferredTheme());
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NetUrlScanner.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm bg-body-tertiary border-bottom box-shadow mb-3">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold text-body"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Landing">
                    NetURLScanner
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-body"
                               asp-area=""
                               asp-controller="UrlScanner"
                               asp-action="Index">
                                Quét URL
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body"
                               asp-area=""
                               asp-controller="UrlScanner"
                               asp-action="History">
                                Lịch sử quét
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body"
                               asp-area=""
                               asp-controller="TrustedBrands"
                               asp-action="Index">
                                Whitelist
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body"
                               asp-area=""
                               asp-controller="BlacklistedDomains"
                               asp-action="Index">
                                Blacklist
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-body"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Privacy">
                                Giới thiệu
                            </a>
                        </li>
                    </ul>

                    <!-- Nút chuyển đổi Dark Mode -->
                    <div class="d-flex align-items-center ms-auto mt-2 mt-sm-0">
                        <button class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                id="themeToggle"
                                style="width: 32px; height: 32px;"
                                title="Chuyển chế độ Sáng/Tối"
                                type="button">
                            <i class="bi bi-moon-fill"></i>
                        </button>
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1055;"></div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - NetURLScanner
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Script xử lý hiển thị TempData bằng Toast -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            @if (TempData["Success"] != null)
            {
                var successMsg = TempData["Success"]?.ToString() ?? string.Empty;
                <text>window.showToast('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(successMsg))', 'success');</text>
            }
            @if (TempData["Error"] != null)
            {
                var errorMsg = TempData["Error"]?.ToString() ?? string.Empty;
                <text>window.showToast('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(errorMsg))', 'danger');</text>
            }
        });
    </script>

    <!-- Script xử lý sự kiện nút Dark Mode -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('themeToggle');

        if (!toggleBtn) {
        return;
        }

        const icon = toggleBtn.querySelector('i');
        const currentTheme = document.documentElement.getAttribute('data-bs-theme');

        if (currentTheme === 'dark') {
        icon.classList.remove('bi-moon-fill');
        icon.classList.add('bi-sun-fill');
        } else {
        icon.classList.remove('bi-sun-fill');
        icon.classList.add('bi-moon-fill');
        }

        toggleBtn.addEventListener('click', () => {
        const html = document.documentElement;
        const isDark = html.getAttribute('data-bs-theme') === 'dark';
        const newTheme = isDark ? 'light' : 'dark';

        html.setAttribute('data-bs-theme', newTheme);
        localStorage.setItem('theme', newTheme);

        if (newTheme === 'dark') {
        icon.classList.remove('bi-moon-fill');
        icon.classList.add('bi-sun-fill');
        } else {
        icon.classList.remove('bi-sun-fill');
        icon.classList.add('bi-moon-fill');
        }
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>