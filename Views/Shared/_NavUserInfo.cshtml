@inject NetURLScanner.Services.UserAuthService UserAuth
@{
    var nav = await UserAuth.GetNavInfoAsync(User);
}
@if (nav != null)
{
    <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary btn-sm position-relative" title="@(nav.IsPremium ? "Hồ sơ cá nhân (VIP Premium)" : "Hồ sơ cá nhân")">
        <i class="bi bi-person-circle"></i>
        @if (nav.IsPremium)
        {
            <span class="nav-vip-dot" title="Gói Premium"></span>
        }
    </a>
    <span class="text-muted me-2 d-none d-md-inline">
        Xin chào, @nav.Email
        @if (nav.IsPremium)
        {
            <span class="nav-vip-badge ms-1" title="Gói Premium đang hoạt động">
                <i class="bi bi-star-fill"></i> VIP
            </span>
        }
    </span>
}
