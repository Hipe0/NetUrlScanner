@{
    var baseUrl = ViewData["ExportBaseUrl"] as string ?? "";
    var query = ViewData["ExportQuery"] as string ?? "";
    var fullQuery = string.IsNullOrEmpty(query) ? "" : "?" + query;
}

<div class="btn-group">
    <button type="button" class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="bi bi-download me-1"></i>Xuất báo cáo
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
        <li><a class="dropdown-item" href="@($"{baseUrl}/ExportCsv{fullQuery}")"><i class="bi bi-filetype-csv me-2"></i>CSV</a></li>
        <li><a class="dropdown-item" href="@($"{baseUrl}/ExportExcel{fullQuery}")"><i class="bi bi-file-earmark-excel me-2"></i>Excel</a></li>
        <li><a class="dropdown-item" href="@($"{baseUrl}/ExportHistoryPdf{fullQuery}")"><i class="bi bi-file-earmark-pdf me-2"></i>PDF</a></li>
    </ul>
</div>
