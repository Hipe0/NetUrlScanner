<div id="ai-chatbox-container">
    <div id="ai-chat-window" hidden>
        <div id="ai-chat-header">
            <span><i class="bi bi-robot me-2" aria-hidden="true"></i>Trợ lý AI</span>
            <button type="button" id="ai-chat-close" aria-label="Đóng chat"><i class="bi bi-x"></i></button>
        </div>
        <div id="ai-chat-messages">
            <div class="chat-msg bot">
                Chào bạn! Tôi là trợ lý AI của NetURLScanner. Tôi có thể giúp gì cho bạn hôm nay?
            </div>
        </div>
        <div class="typing-indicator" id="ai-typing" hidden>Đang trả lời...</div>
        <div id="ai-chat-input-area">
            <input type="text" id="ai-chat-input" placeholder="Nhập câu hỏi..." autocomplete="off" aria-label="Tin nhắn" />
            <button type="button" id="ai-chat-send" aria-label="Gửi"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>
    <button type="button" id="ai-chat-btn" title="Hỏi đáp cùng AI" aria-expanded="false" aria-controls="ai-chat-window">
        <i class="bi bi-chat-dots-fill" aria-hidden="true"></i>
    </button>
</div>
<script src="~/js/chatbox.js" asp-append-version="true" defer></script>
